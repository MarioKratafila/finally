# Required: OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data
# If not set, the built-in market simulator is used
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (testing)
LLM_MOCK=false

# Optional: number of recent chat messages loaded as LLM context (default: 10)
CHAT_HISTORY_LIMIT=10

# Optional: Massive API poll interval in seconds (default: 15)
PRICE_POLL_INTERVAL_SECONDS=15
